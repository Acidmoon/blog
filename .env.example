# Copy this file to .env and replace both placeholder values before deployment.
BLOG_SECRET_KEY=replace-with-a-long-random-secret
ADMIN_PASSWORD=replace-with-a-strong-admin-password
ADMIN_USERNAME=Acidmoon
COOKIE_SECURE=1
# Keep the container private to the host unless direct public access is intentional.
BLOG_BIND_ADDRESS=127.0.0.1
BLOG_PORT=8082
# Set a new value when browsers need to refresh static assets after a release.
ASSET_VERSION=2026-07-11-request-security
# Leave blank unless a known reverse-proxy CIDR directly connects to the app.
TRUSTED_PROXY_CIDRS=
